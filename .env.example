# MapU local development environment

# Database used by both application runtime and Alembic migrations.
MAPU_DB_URL=postgresql+asyncpg://mapu:mapu@localhost:5432/mapu
MAPU_DB_ECHO=false

# Default local embeddings are deterministic hash vectors for zero-dependency smoke tests.
# For semantic retrieval, install the ml extra and use sentence-transformers.
MAPU_EMBEDDING_PROVIDER=local
MAPU_EMBEDDING_MODEL=hash-deterministic
MAPU_EMBEDDING_DIMENSIONS=384
MAPU_EMBEDDING_BATCH_SIZE=64
MAPU_EMBEDDING_DEVICE=cpu

# Chunking and parser settings.
MAPU_CHUNKING_MAX_TOKENS=512
MAPU_CHUNKING_OVERLAP_TOKENS=64
MAPU_PARSER_ENABLED_TYPES=text/plain
MAPU_SOURCE_POLICY_DEFAULT_DOCUMENT_TYPE=other

# Default local extraction. GLiNER runs locally by default; online LLM extraction stays disabled.
MAPU_EXTRACTION_AUTO_ACCEPT_MIN=0.85
MAPU_EXTRACTION_CANDIDATE_MIN=0.3
MAPU_EXTRACTION_SPACY_MODEL=en_core_web_sm
MAPU_EXTRACTION_GLINER_ENABLED=true
MAPU_EXTRACTION_GLINER_MODEL=urchade/gliner_small-v2.1
MAPU_EXTRACTION_GLINER_THRESHOLD=0.5
MAPU_EXTRACTION_GLINER_CALIBRATION=0.75
MAPU_EXTRACTION_GLINER_RELEX_ENABLED=false
MAPU_EXTRACTION_GLINER_RELEX_MODEL=knowledgator/gliner-relex-base-v1.0
MAPU_EXTRACTION_GLINER_RELEX_ENTITY_THRESHOLD=0.4
MAPU_EXTRACTION_GLINER_RELEX_RELATION_THRESHOLD=0.7
MAPU_EXTRACTION_GLINER_RELEX_CALIBRATION=0.75
MAPU_EXTRACTION_SETFIT_ENABLED=false
MAPU_EXTRACTION_SETFIT_MODEL=sentence-transformers/paraphrase-MiniLM-L3-v2
MAPU_EXTRACTION_SETFIT_TRAINED_PATH=
MAPU_EXTRACTION_SETFIT_THRESHOLD=0.5
MAPU_EXTRACTION_SRL_ENABLED=false
MAPU_EXTRACTION_LLM_ENABLED=false
MAPU_EXTRACTION_LLM_MAX_TOKENS=2048
MAPU_EXTRACTION_LLM_TEMPERATURE=0.0
MAPU_EXTRACTION_LLM_MIN_CONFIDENCE=0.5
MAPU_EXTRACTION_ML_DEVICE=cpu

# Optional LLM provider used by investigation and LLM synthesis paths.
MAPU_LLM_PROVIDER=
MAPU_LLM_MODEL=
MAPU_LLM_API_KEY=
MAPU_LLM_BASE_URL=
MAPU_LLM_TIMEOUT=120

# Optional query synthesis settings.
MAPU_QUERY_LLM_SYNTHESIS_PROVIDER=
MAPU_QUERY_LLM_SYNTHESIS_MODEL=
MAPU_QUERY_LLM_SYNTHESIS_MAX_TOKENS=1024

# Server settings.
MAPU_SERVER_HOST=127.0.0.1
MAPU_SERVER_PORT=8000
MAPU_SERVER_API_KEY=
MAPU_SERVER_CORS_ORIGINS=
